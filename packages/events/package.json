{
  "name": "@theatrical/events",
  "version": "0.1.0",
  "description": "Real-time event bridge for cinema platform APIs — typed polling, diff, and event emission over Vista OCAPI",
  "keywords": [
    "cinema",
    "events",
    "real-time",
    "theatrical",
    "vista",
    "ocapi"
  ],
  "author": "Bruno Hart <hello@theatrical.dev>",
  "license": "BSL-1.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/brunohart/theatrical",
    "directory": "packages/events"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch"
  },
  "dependencies": {
    "@theatrical/sdk": "file:../sdk"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  }
}
