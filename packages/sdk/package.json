{
  "name": "@theatrical/sdk",
  "version": "0.1.1",
  "description": "Type-safe TypeScript SDK for cinema management platform APIs",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "keywords": [
    "cinema",
    "ticketing",
    "sdk",
    "api",
    "theatrical",
    "cinema-management",
    "showtime",
    "booking"
  ],
  "author": "designedbybruno <hello@theatrical.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/brunohart/theatrical",
    "directory": "packages/sdk"
  },
  "publishConfig": {
    "access": "public"
  }
}
