{
  "name": "@theatrical/sdk",
  "version": "0.1.0",
  "description": "Type-safe TypeScript SDK for cinema management platform APIs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "@types/node": "^20.0.0"
  },
  "keywords": ["cinema", "ticketing", "sdk", "api", "theatrical", "cinema-management", "showtime", "booking"],
  "author": "Bruno Hart <hello@theatrical.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/brunohart/theatrical",
    "directory": "packages/sdk"
  }
}
