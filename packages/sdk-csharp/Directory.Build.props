<Project>

  <PropertyGroup>
    <LangVersion>12.0</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <Deterministic>true</Deterministic>
    <ContinuousIntegrationBuild Condition="'$(CI)' == 'true'">true</ContinuousIntegrationBuild>
  </PropertyGroup>

  <PropertyGroup>
    <Authors>designedbybruno</Authors>
    <Company>Theatrical</Company>
    <Copyright>Copyright (c) 2026 designedbybruno</Copyright>
    <PackageProjectUrl>https://github.com/brunohart/theatrical</PackageProjectUrl>
    <RepositoryUrl>https://github.com/brunohart/theatrical</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
  </PropertyGroup>

</Project>
