<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net8.0;netstandard2.1</TargetFrameworks>
    <RootNamespace>Theatrical.Sdk</RootNamespace>
    <AssemblyName>Theatrical.Sdk</AssemblyName>
    <Version>0.1.0</Version>
    <Description>C# SDK for cinema platform APIs. Type-safe client with authentication, rate limiting, retry logic, and mock mode.</Description>
    <PackageId>Theatrical.Sdk</PackageId>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageTags>cinema;api;sdk;ticketing;sessions;booking</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <PropertyGroup>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
    <EnablePackageValidation>true</EnablePackageValidation>
    <PackageValidationBaselineVersion>0.1.0</PackageValidationBaselineVersion>
    <MinVerTagPrefix>v</MinVerTagPrefix>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.SourceLink.GitHub" PrivateAssets="All" />
    <PackageReference Include="Polly" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Theatrical.Sdk.Tests" />
  </ItemGroup>

  <ItemGroup>
    <None Include="../../README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>
