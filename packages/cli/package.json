{
  "name": "@theatrical/cli",
  "version": "0.1.0",
  "description": "Developer CLI for cinema platform APIs \u2014 scaffold, codegen, and inspect",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "theatrical": "./bin/theatrical.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@theatrical/sdk": "file:../sdk",
    "commander": "^12.1.0",
    "chalk": "^5.3.0",
    "inquirer": "^9.2.0",
    "cosmiconfig": "^9.0.0",
    "ora": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/inquirer": "^9.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "keywords": [
    "cinema",
    "cli",
    "codegen",
    "api",
    "theatrical",
    "developer-tools"
  ],
  "author": "Bruno Hart <hello@theatrical.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/brunohart/theatrical",
    "directory": "packages/cli"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
