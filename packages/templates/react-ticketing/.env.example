# Theatrical React Ticketing Template — Environment Variables

# Vista API credentials
# Get your API key at https://developers.theatrical.dev
VITE_THEATRICAL_API_KEY=your_api_key_here

# Vista site ID — the cinema site to display sessions for
# Use 'theatrical inspect sites list' to find site IDs
VITE_THEATRICAL_SITE_ID=site_roxy_wellington

# Set to 'false' to use the real Vista API instead of mock data
# Requires VITE_THEATRICAL_API_KEY to be set
VITE_THEATRICAL_MOCK=true

# API target environment (sandbox | staging | production)
VITE_THEATRICAL_ENV=sandbox
