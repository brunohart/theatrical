{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }],
  "env": {
    "VITE_THEATRICAL_API_KEY": "@theatrical-api-key",
    "VITE_THEATRICAL_SITE_ID": "@theatrical-site-id",
    "VITE_MOCK_MODE": "false"
  }
}
