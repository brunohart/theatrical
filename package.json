{
  "name": "theatrical",
  "version": "0.1.0",
  "private": true,
  "description": "A developer toolkit for cinema management platforms",
  "author": "Bruno Hart <hello@theatrical.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/brunohart/theatrical"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "dev": "turbo run dev"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "prettier": "^3.2.0",
    "eslint": "^9.0.0",
    "typescript": "^5.4.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
